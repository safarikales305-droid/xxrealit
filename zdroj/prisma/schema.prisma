generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  password     String
  role         String    @default("PRIVATE_SELLER")
  createdAt    DateTime  @default(now())
  resetToken   String?   @unique
  resetExpires DateTime?
}
