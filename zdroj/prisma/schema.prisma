generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                              String            @id @default(cuid())
  email                           String            @unique
  password                        String
  role                            UserRole          @default(PRIVATE_SELLER)
  resetToken                      String?
  resetExpires                    DateTime?
  name                            String            @default("")
  phone                           String            @default("")
  phonePublic                     Boolean           @default(false)
  avatar                          String?
  coverImage                      String?
  bio                             String?
  city                            String?
  rating                          Float             @default(0)
  createdAt                       DateTime          @default(now())
  Follow_Follow_followerIdToUser  Follow[]          @relation("Follow_followerIdToUser")
  Follow_Follow_followingIdToUser Follow[]          @relation("Follow_followingIdToUser")
  Property                        Property[]
  PropertyComment                 PropertyComment[]
  PropertyLike                    PropertyLike[]
  Story                           Story[]
}

model Follow {
  id                            String   @id
  followerId                    String
  followingId                   String
  createdAt                     DateTime @default(now())
  User_Follow_followerIdToUser  User     @relation("Follow_followerIdToUser", fields: [followerId], references: [id], onDelete: Cascade)
  User_Follow_followingIdToUser User     @relation("Follow_followingIdToUser", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Property {
  id              String            @id
  title           String
  price           Int
  videoUrl        String?
  city            String
  approved        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  userId          String
  User            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  PropertyComment PropertyComment[]
  PropertyLike    PropertyLike[]

  @@index([userId])
}

model PropertyComment {
  id         String   @id
  propertyId String
  userId     String
  body       String
  createdAt  DateTime @default(now())
  Property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  User       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model PropertyLike {
  id         String   @id
  propertyId String
  userId     String
  createdAt  DateTime @default(now())
  Property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  User       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([propertyId, userId])
  @@index([propertyId])
  @@index([userId])
}

enum UserRole {
  USER
  AGENT
  DEVELOPER
  PRIVATE_SELLER
  ADMIN
}

enum StoryType {
  IMAGE
  VIDEO
}

model Story {
  id           String    @id @default(cuid())
  userId       String
  type         StoryType
  mediaUrl     String
  thumbnailUrl String?
  isPublic     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  expiresAt    DateTime
  User         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt, isPublic])
  @@index([userId, createdAt])
}
