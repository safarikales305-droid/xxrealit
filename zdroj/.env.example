# --- HTTPS / mixed content ---
# Na produkci (https://www.xxrealit.cz) musí být API i odkazy vždy https:// — jinak prohlížeč zablokuje requesty (mixed content).
# `NEXT_PUBLIC_*` se inlinuje při `next build`; po změně env znovu sestavte frontend.

# Veřejná URL Nest API (včetně schématu https://). Bez koncového lomítka; přípona /api se doplní v kódu.
NEXT_PUBLIC_API_URL=https://your-nest-api.up.railway.app

# Kanonická URL webu (metadataBase, og, reset hesla). Důrazně doporučeno v produkci.
NEXT_PUBLIC_SITE_URL=https://www.xxrealit.cz

# Alias pro odkazy v e-mailech / interní logice (volitelné; jinak se použije SITE_URL nebo hostingová doména).
# NEXT_PUBLIC_APP_URL=https://www.xxrealit.cz

# Při NEXT_PUBLIC_DEBUG_API=1 vypíše konzole prohlížeče použitou API base (jen diagnostika).
# NEXT_PUBLIC_DEBUG_API=1
