# Neon, Vercel Postgres, or any PostgreSQL provider (use the pooled URL on Vercel when offered).
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"

# Must be a long random string in production. Used by jsonwebtoken (login) and jose (middleware).
JWT_SECRET=your-long-random-string

# Nest API (Railway / local). Required in production so SSR and client calls hit the backend.
# NEXT_PUBLIC_API_URL=https://xxrealit-production.up.railway.app
# API_URL=https://xxrealit-production.up.railway.app
# Local dev (backend on :3000, Next on :3001):
# NEXT_PUBLIC_API_URL=http://localhost:3000
# API_URL=http://localhost:3000
