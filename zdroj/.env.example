# Neon, Vercel Postgres, or any PostgreSQL provider (use the pooled URL on Vercel when offered).
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"

# Must be a long random string in production. Used by jsonwebtoken (login) and jose (middleware).
JWT_SECRET=your-long-random-string

# Nest API base URL (optional) — only if you still proxy routes to Nest.
# NEXT_PUBLIC_API_URL=http://localhost:3000
# API_URL=http://localhost:3000
