# Veřejná URL Nest API (musí končit na stejnou doménu jako CORS na backendu).
# Build: hodnota se inlinuje do klienta. Na Vercel/Railway nastavte produkční API.
NEXT_PUBLIC_API_URL=https://your-nest-api.up.railway.app

# Volitelně: vlastní veřejná URL webu (pro odkazy). Backend CORS defaultně zahrnuje www.xxrealit.cz.
# NEXT_PUBLIC_SITE_URL=https://www.xxrealit.cz

# Při NEXT_PUBLIC_DEBUG_API=1 vypíše konzole prohlížeče použitou API base (jen diagnostika).
# NEXT_PUBLIC_DEBUG_API=1
