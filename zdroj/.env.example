# Nest API base URL (no trailing slash). Required on Vercel for server-side /properties.
NEXT_PUBLIC_API_URL=http://localhost:3000

# Optional: server-only API URL for Route Handlers (defaults to NEXT_PUBLIC_API_URL).
# API_URL=http://localhost:3000

# NextAuth / Auth.js — required in production (e.g. Vercel). Generate: openssl rand -base64 32
AUTH_SECRET=

# Canonical site URL for Auth.js (set on Vercel to your deployment URL, e.g. https://app.example.com)
AUTH_URL=

# Nest issues access tokens signed with this secret — must match nestjs-backend JWT_SECRET.
JWT_SECRET=your-long-random-string

# Optional: Google OAuth (also enables provider when both are set). Linking to Nest JWT is not wired yet.
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
