# Local: SQLite (path relative to prisma/). Production (Railway + Neon): Postgres URL.
# DATABASE_URL="file:./dev.db"
# Railway → Variables: DATABASE_URL=PASTE_YOUR_NEON_DATABASE_URL
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"

# Nest listens on PORT (default 3000)
# PORT=3000

# Comma-separated origins for CORS
# CORS_ORIGIN=http://localhost:3001,http://127.0.0.1:3001

# Must match Next.js JWT_SECRET for cookie session verification
# JWT_SECRET=your-long-random-string
