# Local: SQLite (path relative to prisma/). Production (Railway + Neon): Postgres URL.
# DATABASE_URL="file:./dev.db"
# Railway → Variables: DATABASE_URL=PASTE_YOUR_NEON_DATABASE_URL
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"

# Nest listens on PORT (default 3000)
# PORT=3000

# CORS: produkční domény (doplňte / přepište). V kódu jsou defaultně https://www.xxrealit.cz a https://xxrealit.cz.
# FRONTEND_URL=https://www.xxrealit.cz
# CORS_ORIGINS=https://www.xxrealit.cz,https://xxrealit.cz
# Další hlavičky pro preflight (volitelné): CORS_EXTRA_HEADERS=X-Custom-Header
# Prázdný shorts feed → 1 demo video: SHORTS_FEED_FALLBACK_DEMO=1 (jen dočasně)

# Must match Next.js JWT_SECRET for cookie session verification
# JWT_SECRET=your-long-random-string
