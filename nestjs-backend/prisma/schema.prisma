generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  makler
  kancelar
  sledujici
  soukromy
  remeslnik
  stavebni_firma
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  name         String?
  passwordHash String
  role         UserRole   @default(sledujici)
  createdAt    DateTime   @default(now())
  properties   Property[]
}

model Property {
  id        String   @id @default(uuid())
  title     String
  price     Int
  videoUrl  String?
  city      String
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
