generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  AGENT
  DEVELOPER
  PRIVATE_SELLER
  ADMIN
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  name         String?
  password     String
  role         UserRole   @default(USER)
  /// Public profile image URL (absolute or same-origin path).
  avatar       String?
  bio          String?
  /// User's own city (for personalization); separate from listing city.
  city         String?
  /// Average rating 0–5 (manual / future reviews).
  rating       Float      @default(0)
  createdAt    DateTime   @default(now())
  resetToken   String?
  resetExpires DateTime?

  properties   Property[]
  videos       Video[]
  likes        PropertyLike[]
  comments     PropertyComment[]

  following    Follow[]   @relation("UserFollowing")
  followers    Follow[]   @relation("UserFollowers")
}

model Video {
  id          String   @id @default(cuid())
  url         String
  description String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Follow {
  id           String   @id @default(uuid())
  followerId   String
  followingId  String
  createdAt    DateTime @default(now())

  follower     User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following    User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Property {
  id              String   @id @default(uuid())
  title           String
  description     String   @db.Text
  status          String   @default("PENDING")
  price           Int
  currency        String   @default("CZK")

  /// prodej | pronájem
  offerType       String   @default("prodej")
  /// byt | dům | pozemek | …
  propertyType    String   @default("byt")
  subType         String   @default("")

  address         String   @default("")
  city            String

  area            Float?
  landArea        Float?
  floor           Int?
  totalFloors     Int?

  condition       String?
  construction    String?
  ownership       String?
  energyLabel     String?

  equipment       String?  @db.Text
  parking         Boolean  @default(false)
  cellar          Boolean  @default(false)

  images          String[] @default([])
  videoUrl        String?

  contactName     String   @default("")
  contactPhone    String   @default("")
  contactEmail    String   @default("")

  /// Ve veřejném výpisu jen schválené; admin vidí vše.
  approved        Boolean  @default(false)
  createdAt       DateTime @default(now())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  likes     PropertyLike[]
  comments  PropertyComment[]

  @@index([userId])
}

model Visit {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
}

model PropertyLike {
  id         String   @id @default(uuid())
  propertyId String
  userId     String
  createdAt  DateTime @default(now())

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([propertyId, userId])
  @@index([propertyId])
  @@index([userId])
}

/// Reserved for future comments UI — API structure only.
model PropertyComment {
  id         String   @id @default(uuid())
  propertyId String
  userId     String
  body       String
  createdAt  DateTime @default(now())

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}
