generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  AGENT
  COMPANY
  AGENCY
  FINANCIAL_ADVISOR
  INVESTOR
  DEVELOPER
  PRIVATE_SELLER
  ADMIN
}

enum PostCategory {
  MAKLERI
  STAVEBNI_FIRMY
  REALITNI_KANCELARE
  FINANCNI_PORADCI
  INVESTORI
  REMESLNICI
}

enum AgentVerificationStatus {
  pending
  verified
  rejected
}

enum ReactionType {
  LIKE
  DISLIKE
}

enum StoryType {
  IMAGE
  VIDEO
}

enum ShortsListingStatus {
  draft
  ready
  published
}

/// Stav posledního pokusu o vygenerování shorts videa (nezasahuje do ShortsListingStatus).
enum ShortsVideoRenderStatus {
  idle
  rendering
  failed
}

enum EmailLogStatus {
  queued
  sent
  failed
}

enum EmailCampaignStatus {
  draft
  scheduled
  sent
  failed
}

enum ListingImportMethod {
  soap
  scraper
  apify
  xml
  csv
  other
}

enum ListingImportPortal {
  reality_cz
  century21_cz
  apify
  xml_feed
  csv_feed
  other
}

/// Z čeho lze u inzerátu skládat shorts (video / fotky / nic).
enum PropertyShortsSourceType {
  video
  images
  none
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  name         String     @default("")
  phone        String     @default("")
  phonePublic  Boolean    @default(false)
  password     String
  role         UserRole   @default(USER)
  /// Public profile image URL (absolute or same-origin path).
  avatar       String?
  /// Volitelné UI nastavení výřezu profilové fotky (x/y posun, zoom).
  avatarCrop   Json?
  /// Široký cover obrázek profilu (URL).
  coverImage   String?
  /// Volitelné UI nastavení výřezu cover fotky (x/y posun, zoom).
  coverCrop    Json?
  bio          String?
  /// User's own city (for personalization); separate from listing city.
  city         String?
  /// Average rating 0–5 (manual / future reviews).
  rating       Float      @default(0)
  creditBalance Int       @default(0)
  createdAt    DateTime   @default(now())
  resetToken   String?
  resetExpires DateTime?

  properties   Property[]
  videos       Video[]
  posts        Post[]
  postReactions PostReaction[]
  postFavorites Favorite[]
  postComments  Comment[]
  likes        PropertyLike[]
  comments     PropertyComment[]

  following    Follow[]   @relation("UserFollowing")
  followers    Follow[]   @relation("UserFollowers")

  conversationsLow  PropertyConversation[] @relation("ConvUserLow")
  conversationsHigh PropertyConversation[] @relation("ConvUserHigh")
  propertyMessagesSent PropertyMessage[]   @relation("PropertyMessageSender")

  shortsMusicTracksUploaded ShortsMusicTrack[]
  companyAds CompanyAd[]

  /// Placený / aktivní „Premium makléř“ — notifikace na vlastnické inzeráty, kontakt při souhlasu.
  isPremiumBroker                  Boolean  @default(false)
  /// Zapnout/vypnout notifikace o nových vlastnických inzerátech (jen AGENT + isPremiumBroker).
  brokerLeadNotificationEnabled    Boolean  @default(true)
  /// Filtr krajů / oblastí (řetězce, case-insensitive match proti Property.region nebo city).
  brokerPreferredRegions           String[] @default([])
  brokerPreferredPropertyTypes     String[] @default([])
  brokerPoints                     Int      @default(0)
  /// Odměnové leady z gamifikace (kontaktování vlastnických inzerátů bez premium).
  brokerFreeLeads                  Int      @default(0)

  /// Veřejná stránka makléře v katalogu /makleri.
  isPublicBrokerProfile Boolean  @default(false)
  /// Zobrazit sekci hodnocení a přijímat nové recenze.
  allowBrokerReviews    Boolean  @default(false)
  /// Jedinečný slug pro URL /makler/[slug].
  brokerProfileSlug     String?  @unique
  brokerOfficeName      String   @default("")
  brokerSpecialization  String   @default("")
  brokerRegionLabel     String   @default("")
  brokerWeb             String   @default("")
  brokerPhonePublic     String   @default("")
  brokerEmailPublic     String   @default("")
  /// Agregát z viditelných recenzí (přepočet při změně recenze).
  brokerReviewAverage   Float    @default(0)
  brokerReviewCount     Int      @default(0)

  notifications        UserNotification[]
  brokerPointsLedger   BrokerPointsLedger[]
  brokerLeadOffers     BrokerLeadOffer[] @relation("UserBrokerLeads")
  brokerReviewsReceived BrokerReview[] @relation("BrokerReviewsTarget")
  brokerReviewsWritten  BrokerReview[] @relation("BrokerReviewsAuthor")

  agentProfile AgentProfile?
  companyProfile CompanyProfile?
  agencyProfile AgencyProfile?
  financialAdvisorProfile FinancialAdvisorProfile?
  investorProfile InvestorProfile?
  stories Story[]

  shortsListings ShortsListing[] @relation("UserShortsListings")
}

model Story {
  id           String    @id @default(cuid())
  userId       String
  type         StoryType
  mediaUrl     String
  thumbnailUrl String?
  isPublic     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  expiresAt    DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt, isPublic])
  @@index([userId, createdAt])
}

model AgentProfile {
  id                   String                  @id @default(cuid())
  userId               String                  @unique
  fullName             String
  companyName          String
  phone                String
  phoneVerified        Boolean                 @default(false)
  website              String                  @default("")
  ico                  String                  @default("")
  city                 String
  bio                  String                  @db.Text
  avatarUrl            String?
  isPublic             Boolean                 @default(false)
  verificationStatus   AgentVerificationStatus @default(pending)
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([verificationStatus, createdAt])
}

model CompanyProfile {
  id                 String                  @id @default(cuid())
  userId             String                  @unique
  companyName        String
  contactFullName    String
  phone              String
  email              String
  website            String                  @default("")
  ico                String                  @default("")
  city               String
  description        String                  @db.Text
  services           String                  @db.Text
  logoUrl            String?
  isPublic           Boolean                 @default(false)
  verificationStatus AgentVerificationStatus @default(pending)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([verificationStatus, createdAt])
}

model CompanyAd {
  id          String   @id @default(cuid())
  companyId   String
  imageUrl    String
  title       String
  description String   @db.Text
  ctaText     String
  targetUrl   String
  categories  String[] @default([])
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company User @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, isActive])
  @@index([isActive, updatedAt])
}

model EmailLog {
  id                String         @id @default(cuid())
  type              String
  templateKey       String?
  subject           String
  recipientEmail    String
  senderEmail       String?
  senderName        String?
  status            EmailLogStatus @default(queued)
  provider          String         @default("resend")
  providerMessageId String?
  errorMessage      String?
  payloadJson       Json?
  createdAt         DateTime       @default(now())
  sentAt            DateTime?

  @@index([type, createdAt])
  @@index([status, createdAt])
  @@index([recipientEmail, createdAt])
}

model EmailTemplate {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  subject     String
  htmlContent String   @db.Text
  textContent String   @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EmailCampaign {
  id          String              @id @default(cuid())
  type        String
  title       String
  subject     String
  templateKey String?
  htmlContent String              @db.Text
  status      EmailCampaignStatus @default(draft)
  audienceJson Json?
  createdAt   DateTime            @default(now())
  scheduledAt DateTime?
  sentAt      DateTime?

  @@index([status, createdAt])
  @@index([type, createdAt])
}

model AgencyProfile {
  id                 String                  @id @default(cuid())
  userId             String                  @unique
  agencyName         String
  contactFullName    String
  phone              String
  email              String
  website            String                  @default("")
  ico                String                  @default("")
  city               String
  description        String                  @db.Text
  logoUrl            String?
  isPublic           Boolean                 @default(false)
  agentCount         Int?
  branchCities       String[]
  verificationStatus AgentVerificationStatus @default(pending)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([verificationStatus, createdAt])
}

model FinancialAdvisorProfile {
  id                 String                  @id @default(cuid())
  userId             String                  @unique
  fullName           String
  brandName          String                  @default("")
  phone              String
  email              String
  website            String                  @default("")
  ico                String                  @default("")
  city               String
  bio                String                  @db.Text
  specializations    String[]
  avatarUrl          String?
  logoUrl            String?
  isPublic           Boolean                 @default(false)
  verificationStatus AgentVerificationStatus @default(pending)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([verificationStatus, createdAt])
}

model InvestorProfile {
  id                 String                  @id @default(cuid())
  userId             String                  @unique
  fullName           String
  investorName       String                  @default("")
  investorType       String                  @default("")
  phone              String
  email              String
  website            String                  @default("")
  city               String
  bio                String                  @db.Text
  investmentFocus    String[]
  avatarUrl          String?
  logoUrl            String?
  isPublic           Boolean                 @default(false)
  verificationStatus AgentVerificationStatus @default(pending)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([verificationStatus, createdAt])
}

/// Admin spravovaná hudba pro generované shorts z fotek (výběr uživatelem při tvorbě inzerátu).
model ShortsMusicTrack {
  id                 String   @id @default(cuid())
  title              String
  /// Interpretace jako „interpret“ ve výběru hudby na webu.
  artist             String   @default("")
  description        String?  @db.Text
  fileUrl            String
  /// Volitelná kratší ukázka; pokud chybí, klient může použít fileUrl.
  previewUrl         String?
  cloudinaryPublicId String?
  mimeType           String
  durationSec        Int?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  uploadedById       String
  uploadedBy         User     @relation(fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([isActive])
  @@index([createdAt])
}

model Post {
  id          String   @id @default(cuid())
  title       String   @default("")
  description String   @default("")
  price       Int      @default(0)
  city        String   @default("")
  latitude    Float?
  longitude   Float?
  type        String   @default("post")
  category    PostCategory @default(MAKLERI)
  content     String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  media       Media[]
  reactions   PostReaction[]
  favorites   Favorite[]
  comments    Comment[]
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([latitude, longitude])
}

model PostReaction {
  id        String       @id @default(cuid())
  userId    String
  postId    String
  type      ReactionType
  createdAt DateTime     @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
  @@index([userId])
}

model Media {
  id        String @id @default(cuid())
  url       String
  type      String
  order     Int
  postId    String
  post      Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([order])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([postId])
  @@index([createdAt])
}

model Video {
  id          String   @id @default(cuid())
  url         String
  description String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Follow {
  id           String   @id @default(uuid())
  followerId   String
  followingId  String
  createdAt    DateTime @default(now())

  follower     User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following    User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Property {
  id              String   @id @default(uuid())
  title           String
  description     String   @db.Text
  status          String   @default("PENDING")
  /// null = cena neuvedena / na dotaz (import bez parsované ceny)
  price           Int?
  currency        String   @default("CZK")

  /// prodej | pronájem
  offerType       String   @default("prodej")
  /// byt | dům | pozemek | …
  propertyType    String   @default("byt")
  subType         String   @default("")

  address         String   @default("")
  city            String

  area            Float?
  landArea        Float?
  floor           Int?
  totalFloors     Int?

  condition       String?
  construction    String?
  ownership       String?
  energyLabel     String?

  equipment       String?  @db.Text
  parking         Boolean  @default(false)
  cellar          Boolean  @default(false)

  images          String[] @default([])
  videoUrl        String?

  contactName     String   @default("")
  contactPhone    String   @default("")
  contactEmail    String   @default("")

  /// Ve veřejném výpisu jen schválené; admin vidí vše v admin API.
  approved        Boolean  @default(false)
  /// Soft delete — veřejně se nezobrazuje.
  deletedAt       DateTime?
  /// Admin / uživatel může vypnout veřejné zobrazení (skrytý / neaktivní).
  isActive        Boolean  @default(true)
  /// Začátek veřejného zobrazení (null = ihned po splnění ostatních podmínek).
  activeFrom      DateTime?
  /// Konec veřejného zobrazení (null = bez konce). Po překročení = expirovaný.
  activeUntil     DateTime?
  /// SHORTS (video) | CLASSIC (bez videa) — pro admin přehled a filtry.
  listingType     String   @default("CLASSIC")
  /// Reálný počet zhlédnutí shorts/video.
  viewsCount      Int      @default(0)
  /// Admin autopilot views.
  autoViewsEnabled Boolean @default(false)
  autoViewsIncrement Int   @default(100)
  autoViewsIntervalMinutes Int @default(1)
  lastAutoViewsAt DateTime?

  /// Uživatel označil inzerát jako přímý prodej od vlastníka (bez RK).
  isOwnerListing       Boolean  @default(false)
  /// Souhlas se zobrazením kontaktu premium makléřům (telefon/e-mail).
  ownerContactConsent  Boolean  @default(false)
  /// Volitelné pro matching notifikací (kraj / oblast).
  region               String   @default("")
  district             String   @default("")

  /// Pokud tento SHORTS inzerát vznikl z klasického, ID zdrojového inzerátu.
  derivedFromPropertyId String?
  derivedFromProperty   Property?  @relation("PropertyShortsDerivation", fields: [derivedFromPropertyId], references: [id], onDelete: SetNull)
  shortsDerivedFromThis Property[] @relation("PropertyShortsDerivation")

  /// Integrace importu inzerátů (Reality.cz SOAP/Scraper/XML/CSV...).
  importSource     ListingImportPortal?
  importMethod     ListingImportMethod?
  importExternalId String?
  importSourceUrl  String?
  importedAt       DateTime?
  lastSyncedAt     DateTime?
  /// Ručně vypnutý importovaný inzerát – synchronizace ho znovu neaktivuje.
  importDisabled   Boolean @default(false)

  /// Klasifikace importu (filtry, budoucí portály) — `importSource` zůstává enum v DB.
  sourcePortalKey      String                    @default("")
  sourcePortalLabel    String                    @default("")
  propertyTypeKey      String                    @default("")
  propertyTypeLabel    String                    @default("")
  importCategoryKey    String                    @default("")
  importCategoryLabel  String                    @default("")
  canGenerateShorts   Boolean                   @default(false)
  shortsGenerated     Boolean                   @default(false)
  shortsSourceType    PropertyShortsSourceType  @default(none)

  /// Čas zveřejnění shorts (řazení feedu); klasické inzeráty mohou mít null.
  publishedAt DateTime?

  shortsListingSources     ShortsListing[] @relation("ShortsListingSourceProperty")
  publishedFromShortsDraft ShortsListing? @relation("PublishedShortsProperty")

  createdAt       DateTime @default(now())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  likes     PropertyLike[]
  comments  PropertyComment[]
  media     PropertyMedia[]
  conversations PropertyConversation[]
  brokerLeadOffers BrokerLeadOffer[]
  importedBrokerContactLinks ImportedBrokerContactListing[]

  @@index([userId])
  @@index([derivedFromPropertyId])
  @@index([deletedAt, isActive, approved])
  @@index([isOwnerListing, createdAt])
  @@index([listingType, publishedAt])
  @@index([importSource, importMethod])
  @@index([importExternalId, importSource])
  @@index([sourcePortalKey, propertyTypeKey, city])
  @@index([importCategoryKey, sourcePortalKey])
  @@unique([importSource, importExternalId], map: "property_import_source_external_uq")
}

/// Kontakt makléře / RK extrahovaný z importovaných inzerátů (dedupe e-mail → telefon).
model ImportedBrokerContact {
  id             String    @id @default(cuid())
  fullName       String    @default("")
  companyName    String    @default("")
  email          String?
  phone          String?
  website        String?
  /// Klíč portálu / enum hodnota (např. reality_cz)
  sourcePortal   String?
  /// Poslední známá URL inzerátu (zdroj)
  sourceUrl      String?
  city           String?
  notes          String?   @db.Text
  firstSeenAt    DateTime  @default(now())
  lastSeenAt     DateTime  @default(now())
  listingCount   Int       @default(0)
  /// ACTIVE | INCOMPLETE | ARCHIVED
  status         String    @default("ACTIVE")
  profileCreated Boolean   @default(false)
  invitedAt      DateTime?
  /// none | contacted | emailed | prepared_mail | …
  outreachStatus String    @default("none")
  outreachNote   String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  listings ImportedBrokerContactListing[]

  @@index([email])
  @@index([phone])
  @@index([sourcePortal])
  @@index([lastSeenAt(sort: Desc)])
  @@index([listingCount(sort: Desc)])
  @@index([outreachStatus])
  @@index([profileCreated])
}

model ImportedBrokerContactListing {
  id         String   @id @default(cuid())
  contactId  String
  propertyId String
  sourceUrl  String?
  createdAt  DateTime @default(now())

  contact  ImportedBrokerContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  property Property              @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([contactId, propertyId])
  @@index([propertyId])
}

model ImportSource {
  id             String             @id @default(cuid())
  portal         ListingImportPortal
  method         ListingImportMethod
  name           String
  portalKey      String             @default("")
  portalLabel    String             @default("")
  categoryKey    String             @default("obecne")
  categoryLabel  String             @default("Obecné")
  listingType    String?
  propertyType   String?
  sortOrder      Int                @default(0)
  enabled        Boolean            @default(false)
  intervalMinutes Int               @default(60)
  limitPerRun    Int                @default(100)
  endpointUrl    String?
  actorId        String?
  actorTaskId    String?
  datasetId      String?
  startUrl       String?
  sourcePortal   String?
  notes          String?             @db.Text
  isActive       Boolean             @default(true)
  lastRunId      String?
  lastDatasetId  String?
  lastProcessedUrl String?
  lastError      String?
  credentialsJson Json?
  settingsJson   Json?
  lastRunAt      DateTime?
  lastStatus     String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  logs           ImportLog[]

  @@unique([portalKey, categoryKey, method], map: "import_source_portal_category_method_uq")
  @@index([enabled, updatedAt])
  @@index([portalKey, sortOrder, categoryLabel])
  @@index([portalKey, categoryKey])
}

model ImportLog {
  id             String             @id @default(cuid())
  sourceId       String
  portal         ListingImportPortal
  method         ListingImportMethod
  status         String
  message        String?
  importedNew    Int                @default(0)
  importedUpdated Int               @default(0)
  skipped        Int                @default(0)
  disabled       Int                @default(0)
  error          String?
  payloadJson    Json?
  createdAt      DateTime           @default(now())
  source         ImportSource       @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId, createdAt])
  @@index([portal, method, createdAt])
}

model ShortsListing {
  id                  String              @id @default(cuid())
  userId              String
  sourceListingId     String
  publishedPropertyId String?             @unique
  title               String
  description         String              @db.Text
  coverImage          String?
  musicUrl            String              @default("")
  musicTrackId        String?
  musicBuiltinKey     String              @default("demo_soft")
  videoUrl            String?
  renderData          Json?
  videoRenderStatus   ShortsVideoRenderStatus @default(idle)
  videoRenderError    String?             @db.Text
  renderVersion       Int                 @default(0)
  status              ShortsListingStatus @default(draft)
  publishedAt         DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  user              User              @relation("UserShortsListings", fields: [userId], references: [id], onDelete: Cascade)
  sourceListing     Property          @relation("ShortsListingSourceProperty", fields: [sourceListingId], references: [id], onDelete: Cascade)
  publishedProperty Property?         @relation("PublishedShortsProperty", fields: [publishedPropertyId], references: [id], onDelete: SetNull)
  media               ShortsMediaItem[]

  @@index([userId, status])
  @@index([sourceListingId])
}

model ShortsMediaItem {
  id              String   @id @default(cuid())
  shortsListingId String
  imageUrl        String
  order           Int
  duration        Float    @default(3)
  isCover         Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  shortsListing ShortsListing @relation(fields: [shortsListingId], references: [id], onDelete: Cascade)

  @@index([shortsListingId, order])
}

model PropertyMedia {
  id         String   @id @default(cuid())
  propertyId String
  url        String
  /// Původní URL bez watermarku (fallback i při vypnuté funkci).
  originalUrl String?
  /// Odvozená URL s watermarkem (může chybět při selhání generování).
  watermarkedUrl String?
  type       String
  sortOrder  Int
  createdAt  DateTime @default(now())

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([sortOrder])
}

model AppSetting {
  key       String   @id
  valueJson Json
  updatedAt DateTime @updatedAt
}

model Visit {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
}

model PropertyLike {
  id         String   @id @default(uuid())
  propertyId String
  userId     String
  createdAt  DateTime @default(now())

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([propertyId, userId])
  @@index([propertyId])
  @@index([userId])
}

/// Reserved for future comments UI — API structure only.
model PropertyComment {
  id         String   @id @default(uuid())
  propertyId String
  userId     String
  body       String
  createdAt  DateTime @default(now())

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

/// Konverzace mezi dvěma uživateli ohledně jedné nemovitosti (unikátní pár + property).
model PropertyConversation {
  id         String   @id @default(cuid())
  propertyId String
  userLowId  String
  userHighId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  userLow  User     @relation("ConvUserLow", fields: [userLowId], references: [id], onDelete: Cascade)
  userHigh User     @relation("ConvUserHigh", fields: [userHighId], references: [id], onDelete: Cascade)
  messages PropertyMessage[]

  @@unique([propertyId, userLowId, userHighId])
  @@index([userLowId])
  @@index([userHighId])
  @@index([propertyId])
}

model PropertyMessage {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  body           String   @db.Text
  createdAt      DateTime @default(now())
  readAt         DateTime?

  conversation PropertyConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User                 @relation("PropertyMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
}

/// In-app notifikace (vlastník: nový lead; makléř: nový vlastnický inzerát).
model UserNotification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String    @db.Text
  data      Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

/// Historie bodů + idempotence (dedupeKey).
model BrokerPointsLedger {
  id        String   @id @default(cuid())
  userId    String
  action    String
  points    Int
  dedupeKey String
  meta      Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dedupeKey])
  @@index([userId, createdAt])
}

/// První „lead“ makléře k vlastnickému inzerátu (statistiky, spotřeba free leadu).
model BrokerLeadOffer {
  id           String   @id @default(cuid())
  brokerId     String
  propertyId   String
  usedFreeLead Boolean  @default(false)
  createdAt    DateTime @default(now())

  broker   User     @relation("UserBrokerLeads", fields: [brokerId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([brokerId, propertyId])
  @@index([propertyId])
  @@index([brokerId])
}

/// Hodnocení makléře (jen AGENT jako brokerId).
model BrokerReview {
  id         String   @id @default(cuid())
  brokerId   String
  authorId   String
  rating     Int
  reviewText String   @db.Text
  isVisible  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  broker User @relation("BrokerReviewsTarget", fields: [brokerId], references: [id], onDelete: Cascade)
  author User @relation("BrokerReviewsAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([brokerId, authorId])
  @@index([brokerId, isVisible, createdAt])
}
