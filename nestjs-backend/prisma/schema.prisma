generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  AGENT
  DEVELOPER
  PRIVATE_SELLER
  ADMIN
}

enum PostCategory {
  MAKLERI
  STAVEBNI_FIRMY
  REMESLNICI
  REALITNI_KANCELARE
}

enum AgentVerificationStatus {
  pending
  verified
  rejected
}

enum ReactionType {
  LIKE
  DISLIKE
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  name         String?
  password     String
  role         UserRole   @default(USER)
  /// Public profile image URL (absolute or same-origin path).
  avatar       String?
  /// Široký cover obrázek profilu (URL).
  coverImage   String?
  bio          String?
  /// User's own city (for personalization); separate from listing city.
  city         String?
  /// Average rating 0–5 (manual / future reviews).
  rating       Float      @default(0)
  createdAt    DateTime   @default(now())
  resetToken   String?
  resetExpires DateTime?

  properties   Property[]
  videos       Video[]
  posts        Post[]
  postReactions PostReaction[]
  postFavorites Favorite[]
  postComments  Comment[]
  likes        PropertyLike[]
  comments     PropertyComment[]

  following    Follow[]   @relation("UserFollowing")
  followers    Follow[]   @relation("UserFollowers")

  conversationsLow  PropertyConversation[] @relation("ConvUserLow")
  conversationsHigh PropertyConversation[] @relation("ConvUserHigh")
  propertyMessagesSent PropertyMessage[]   @relation("PropertyMessageSender")

  shortsMusicTracksUploaded ShortsMusicTrack[]

  /// Placený / aktivní „Premium makléř“ — notifikace na vlastnické inzeráty, kontakt při souhlasu.
  isPremiumBroker                  Boolean  @default(false)
  /// Zapnout/vypnout notifikace o nových vlastnických inzerátech (jen AGENT + isPremiumBroker).
  brokerLeadNotificationEnabled    Boolean  @default(true)
  /// Filtr krajů / oblastí (řetězce, case-insensitive match proti Property.region nebo city).
  brokerPreferredRegions           String[] @default([])
  brokerPreferredPropertyTypes     String[] @default([])
  brokerPoints                     Int      @default(0)
  /// Odměnové leady z gamifikace (kontaktování vlastnických inzerátů bez premium).
  brokerFreeLeads                  Int      @default(0)

  /// Veřejná stránka makléře v katalogu /makleri.
  isPublicBrokerProfile Boolean  @default(false)
  /// Zobrazit sekci hodnocení a přijímat nové recenze.
  allowBrokerReviews    Boolean  @default(false)
  /// Jedinečný slug pro URL /makler/[slug].
  brokerProfileSlug     String?  @unique
  brokerOfficeName      String   @default("")
  brokerSpecialization  String   @default("")
  brokerRegionLabel     String   @default("")
  brokerWeb             String   @default("")
  brokerPhonePublic     String   @default("")
  brokerEmailPublic     String   @default("")
  /// Agregát z viditelných recenzí (přepočet při změně recenze).
  brokerReviewAverage   Float    @default(0)
  brokerReviewCount     Int      @default(0)

  notifications        UserNotification[]
  brokerPointsLedger   BrokerPointsLedger[]
  brokerLeadOffers     BrokerLeadOffer[] @relation("UserBrokerLeads")
  brokerReviewsReceived BrokerReview[] @relation("BrokerReviewsTarget")
  brokerReviewsWritten  BrokerReview[] @relation("BrokerReviewsAuthor")

  agentProfile AgentProfile?
}

model AgentProfile {
  id                   String                  @id @default(cuid())
  userId               String                  @unique
  fullName             String
  companyName          String
  phone                String
  phoneVerified        Boolean                 @default(false)
  website              String                  @default("")
  ico                  String                  @default("")
  city                 String
  bio                  String                  @db.Text
  avatarUrl            String?
  verificationStatus   AgentVerificationStatus @default(pending)
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([verificationStatus, createdAt])
}

/// Admin spravovaná hudba pro generované shorts z fotek (výběr uživatelem při tvorbě inzerátu).
model ShortsMusicTrack {
  id                 String   @id @default(cuid())
  title              String
  description        String?  @db.Text
  fileUrl            String
  cloudinaryPublicId String?
  mimeType           String
  durationSec        Int?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  uploadedById       String
  uploadedBy         User     @relation(fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([isActive])
  @@index([createdAt])
}

model Post {
  id          String   @id @default(cuid())
  title       String   @default("")
  description String   @default("")
  price       Int      @default(0)
  city        String   @default("")
  latitude    Float?
  longitude   Float?
  type        String   @default("post")
  category    PostCategory @default(MAKLERI)
  content     String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  media       Media[]
  reactions   PostReaction[]
  favorites   Favorite[]
  comments    Comment[]
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([latitude, longitude])
}

model PostReaction {
  id        String       @id @default(cuid())
  userId    String
  postId    String
  type      ReactionType
  createdAt DateTime     @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
  @@index([userId])
}

model Media {
  id        String @id @default(cuid())
  url       String
  type      String
  order     Int
  postId    String
  post      Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([order])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([postId])
  @@index([createdAt])
}

model Video {
  id          String   @id @default(cuid())
  url         String
  description String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Follow {
  id           String   @id @default(uuid())
  followerId   String
  followingId  String
  createdAt    DateTime @default(now())

  follower     User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following    User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Property {
  id              String   @id @default(uuid())
  title           String
  description     String   @db.Text
  status          String   @default("PENDING")
  price           Int
  currency        String   @default("CZK")

  /// prodej | pronájem
  offerType       String   @default("prodej")
  /// byt | dům | pozemek | …
  propertyType    String   @default("byt")
  subType         String   @default("")

  address         String   @default("")
  city            String

  area            Float?
  landArea        Float?
  floor           Int?
  totalFloors     Int?

  condition       String?
  construction    String?
  ownership       String?
  energyLabel     String?

  equipment       String?  @db.Text
  parking         Boolean  @default(false)
  cellar          Boolean  @default(false)

  images          String[] @default([])
  videoUrl        String?

  contactName     String   @default("")
  contactPhone    String   @default("")
  contactEmail    String   @default("")

  /// Ve veřejném výpisu jen schválené; admin vidí vše v admin API.
  approved        Boolean  @default(false)
  /// Soft delete — veřejně se nezobrazuje.
  deletedAt       DateTime?
  /// Admin / uživatel může vypnout veřejné zobrazení (skrytý / neaktivní).
  isActive        Boolean  @default(true)
  /// Začátek veřejného zobrazení (null = ihned po splnění ostatních podmínek).
  activeFrom      DateTime?
  /// Konec veřejného zobrazení (null = bez konce). Po překročení = expirovaný.
  activeUntil     DateTime?
  /// SHORTS (video) | CLASSIC (bez videa) — pro admin přehled a filtry.
  listingType     String   @default("CLASSIC")

  /// Uživatel označil inzerát jako přímý prodej od vlastníka (bez RK).
  isOwnerListing       Boolean  @default(false)
  /// Souhlas se zobrazením kontaktu premium makléřům (telefon/e-mail).
  ownerContactConsent  Boolean  @default(false)
  /// Volitelné pro matching notifikací (kraj / oblast).
  region               String   @default("")
  district             String   @default("")

  /// Pokud tento SHORTS inzerát vznikl z klasického, ID zdrojového inzerátu.
  derivedFromPropertyId String?
  derivedFromProperty   Property?  @relation("PropertyShortsDerivation", fields: [derivedFromPropertyId], references: [id], onDelete: SetNull)
  shortsDerivedFromThis Property[] @relation("PropertyShortsDerivation")

  createdAt       DateTime @default(now())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  likes     PropertyLike[]
  comments  PropertyComment[]
  media     PropertyMedia[]
  conversations PropertyConversation[]
  brokerLeadOffers BrokerLeadOffer[]

  @@index([userId])
  @@index([derivedFromPropertyId])
  @@index([deletedAt, isActive, approved])
  @@index([isOwnerListing, createdAt])
}

model PropertyMedia {
  id         String   @id @default(cuid())
  propertyId String
  url        String
  type       String
  sortOrder  Int
  createdAt  DateTime @default(now())

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([sortOrder])
}

model Visit {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
}

model PropertyLike {
  id         String   @id @default(uuid())
  propertyId String
  userId     String
  createdAt  DateTime @default(now())

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([propertyId, userId])
  @@index([propertyId])
  @@index([userId])
}

/// Reserved for future comments UI — API structure only.
model PropertyComment {
  id         String   @id @default(uuid())
  propertyId String
  userId     String
  body       String
  createdAt  DateTime @default(now())

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

/// Konverzace mezi dvěma uživateli ohledně jedné nemovitosti (unikátní pár + property).
model PropertyConversation {
  id         String   @id @default(cuid())
  propertyId String
  userLowId  String
  userHighId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  userLow  User     @relation("ConvUserLow", fields: [userLowId], references: [id], onDelete: Cascade)
  userHigh User     @relation("ConvUserHigh", fields: [userHighId], references: [id], onDelete: Cascade)
  messages PropertyMessage[]

  @@unique([propertyId, userLowId, userHighId])
  @@index([userLowId])
  @@index([userHighId])
  @@index([propertyId])
}

model PropertyMessage {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  body           String   @db.Text
  createdAt      DateTime @default(now())
  readAt         DateTime?

  conversation PropertyConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User                 @relation("PropertyMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
}

/// In-app notifikace (vlastník: nový lead; makléř: nový vlastnický inzerát).
model UserNotification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String    @db.Text
  data      Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

/// Historie bodů + idempotence (dedupeKey).
model BrokerPointsLedger {
  id        String   @id @default(cuid())
  userId    String
  action    String
  points    Int
  dedupeKey String
  meta      Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dedupeKey])
  @@index([userId, createdAt])
}

/// První „lead“ makléře k vlastnickému inzerátu (statistiky, spotřeba free leadu).
model BrokerLeadOffer {
  id           String   @id @default(cuid())
  brokerId     String
  propertyId   String
  usedFreeLead Boolean  @default(false)
  createdAt    DateTime @default(now())

  broker   User     @relation("UserBrokerLeads", fields: [brokerId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([brokerId, propertyId])
  @@index([propertyId])
  @@index([brokerId])
}

/// Hodnocení makléře (jen AGENT jako brokerId).
model BrokerReview {
  id         String   @id @default(cuid())
  brokerId   String
  authorId   String
  rating     Int
  reviewText String   @db.Text
  isVisible  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  broker User @relation("BrokerReviewsTarget", fields: [brokerId], references: [id], onDelete: Cascade)
  author User @relation("BrokerReviewsAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([brokerId, authorId])
  @@index([brokerId, isVisible, createdAt])
}
