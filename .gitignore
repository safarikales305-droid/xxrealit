# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Frontend (zdroj) — Vercel Root Directory
zdroj/node_modules/
zdroj/.pnp
zdroj/.pnp.*
zdroj/.yarn/*
!zdroj/.yarn/patches
!zdroj/.yarn/plugins
!zdroj/.yarn/releases
!zdroj/.yarn/versions
zdroj/coverage
zdroj/.next/
zdroj/out/
zdroj/build
zdroj/*.tsbuildinfo

# NestJS backend
nestjs-backend/node_modules/
nestjs-backend/dist/
nestjs-backend/.env
nestjs-backend/prisma/*.db
nestjs-backend/prisma/*.db-journal

# stray build output if dev was run from repo root before `zdroj/` move
/.next/

# misc
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env (templates stay tracked via !*.example)
.env
.env.local
.env.*.local
!.env.example
!**/.env.example

.vercel
node_modules
